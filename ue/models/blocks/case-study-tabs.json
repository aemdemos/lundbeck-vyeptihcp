{
  "definitions": [
    {
      "title": "Case Study Tabs",
      "id": "case-study-tabs",
      "model": "case-study-tabs",
      "filter": "case-study-tabs",
      "plugins": {
        "da": {
          "columns": 0,
          "rows": 0
        }
      }
    },
    {
      "title": "Case Study",
      "id": "case-study-tabs-item",
      "model": "case-study-tabs-item",
      "plugins": {
        "da": {
          "rows": 1,
          "columns": 9,
          "fields": [
            { "name": "image", "selector": "div:nth-child(1)>picture>img[src]" },
            { "name": "imageAlt", "selector": "div:nth-child(1)>picture>img[alt]" },
            { "name": "name", "selector": "div:nth-child(2)" },
            { "name": "age", "selector": "div:nth-child(3)" },
            { "name": "description", "selector": "div:nth-child(4)" },
            { "name": "caseStudy", "selector": "div:nth-child(5)" },
            { "name": "experienceHeading", "selector": "div:nth-child(6)" },
            { "name": "experienceContent", "selector": "div:nth-child(7)" },
            { "name": "goalsHeading", "selector": "div:nth-child(8)" },
            { "name": "goals", "selector": "div:nth-child(9)" }
          ]
        }
      }
    }
  ],
  "models": [
    {
      "id": "case-study-tabs-item",
      "fields": [
        {
          "component": "reference",
          "valueType": "string",
          "name": "image",
          "label": "Profile Image",
          "multi": false
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "imageAlt",
          "label": "Profile Image Alt Text",
          "multi": false
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "name",
          "value": "",
          "label": "Name"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "age",
          "value": "",
          "label": "Age"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "description",
          "value": "",
          "label": "Tab Description"
        },
        {
          "component": "richtext",
          "valueType": "string",
          "name": "caseStudy",
          "value": "",
          "label": "Case Study Content"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "experienceHeading",
          "value": "Previous treatment experience",
          "label": "Treatment Experience Heading"
        },
        {
          "component": "richtext",
          "valueType": "string",
          "name": "experienceContent",
          "value": "",
          "label": "Treatment Experience (one paragraph per column, bold the label)"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "goalsHeading",
          "value": "Patient's treatment goals",
          "label": "Treatment Goals Heading"
        },
        {
          "component": "richtext",
          "valueType": "string",
          "name": "goals",
          "value": "",
          "label": "Treatment Goals Content"
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "case-study-tabs",
      "components": [
        "case-study-tabs-item"
      ]
    }
  ]
}
