{
  "definitions": [
    {
      "title": "Quote (KOL)",
      "id": "quote-kol",
      "model": "quote-kol",
      "plugins": {
        "da": {
          "rows": 3,
          "columns": 1,
          "fields": [
            { "name": "image", "selector": "div:nth-child(1)>picture>img[src]" },
            { "name": "imageAlt", "selector": "div:nth-child(1)>picture>img[alt]" },
            { "name": "quote", "selector": "div:nth-child(2)>div" },
            { "name": "author", "selector": "div:nth-child(3)>div" }
          ]
        }
      }
    }
  ],
  "models": [
    {
      "id": "quote-kol",
      "fields": [
        {
          "component": "reference",
          "valueType": "string",
          "name": "image",
          "label": "Headshot",
          "multi": false
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "imageAlt",
          "label": "Headshot Alt",
          "multi": false
        },
        {
          "component": "richtext",
          "valueType": "string",
          "name": "quote",
          "label": "Quote text",
          "required": true
        },
        {
          "component": "richtext",
          "name": "author",
          "label": "Author (optional)",
          "valueType": "string",
          "description": "Use italics for [cite] tag"
        }
      ]
    }
  ],
  "filters": []
}
